# Coupang Partners Open API (https://partners.coupang.com)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
# 채널/추적용 (문서의 subId)
COUPANG_SUB_ID=my-channel

# OpenAI API (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# 예: gpt-4o-mini, gpt-4o 등 (JSON 모드 지원 모델)
OPENAI_MODEL=gpt-4o-mini

# WordPress — 아래 세 값을 모두 채우면 글이 사이트에 업로드됩니다. 비우면 GPT 글·output 파일만 생성.
WP_BASE_URL=https://your-site.com
WP_USERNAME=
# WordPress.com + 2FA 시: 로그인 비밀번호 말고 wordpress.com/me/security 의 앱 비밀번호(16자)
WP_APPLICATION_PASSWORD=
# draft(임시저장) | publish(바로 공개)
WP_POST_STATUS=draft

# WordPress.com (*.wordpress.com) 전용 — https://developer.wordpress.com/apps/ 에서 앱 등록 후 발급
# 자체 호스팅만 쓰면 비워 두면 됩니다.
WPCOM_CLIENT_ID=
WPCOM_CLIENT_SECRET=

# 키워드 목록 JSON 경로
KEYWORDS_FILE=./data/keywords.json
# 발행 이력(동일 키워드 재발행 방지) — WordPress 업로드 성공 시에만 갱신
PUBLISHED_STATE_FILE=./data/published-state.json

# 상품 개수 (쿠팡 검색 limit 최대 10)
MIN_PRODUCTS=3
MAX_PRODUCTS=5

# 로그 파일 (디렉터리는 미리 두거나 실행 시 생성)
LOG_FILE=./logs/app.log

# 생성된 글 HTML 저장 폴더 (브라우저로 열어볼 수 있음)
OUTPUT_DIR=./output

# 스케줄 (exe 상시 실행 시) — 예: 매일 9·15·21시 (한국시간 아님, 서버 로컬시간)
CRON_SCHEDULE=0 9,15,21 * * *
