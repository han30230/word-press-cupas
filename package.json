{
  "name": "coupang-wp-publisher",
  "version": "1.0.0",
  "description": "Coupang Partners search + OpenAI article + WordPress REST automation",
  "author": "",
  "type": "module",
  "main": "electron/boot.mjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "schedule": "node dist/schedule.js",
    "dev:schedule": "tsx src/schedule.ts",
    "test:wp": "tsx src/scripts/testWp.ts",
    "build:exe": "npm run build && node scripts/build-exe.mjs",
    "build:electron-bundle": "esbuild dist/electron/api-entry.js --bundle --platform=node --target=node18 --outfile=electron/publish-bundle.cjs --format=cjs",
    "electron:dev": "npm run build && npm run build:electron-bundle && electron .",
    "build:electron-app": "npm run build && npm run build:electron-bundle && electron-builder --win portable --publish never"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "pkg": "^5.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.coupangwp.publisher",
    "productName": "CoupangWPublisher",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/node-cron/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "artifactName": "CoupangWPublisher-portable.exe",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
